# Spring profile
SPRING_PROFILES_ACTIVE=local

# Server
SERVER_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sopkathon_ios3
DB_USERNAME=root
DB_PASSWORD=

# NCP Object Storage (S3-compatible)
OBJECT_STORAGE_ENDPOINT=https://kr.object.ncloudstorage.com
OBJECT_STORAGE_REGION=kr-standard
OBJECT_STORAGE_BUCKET=your-bucket-name
OBJECT_STORAGE_ACCESS_KEY=your-access-key
OBJECT_STORAGE_SECRET_KEY=your-secret-key

# Image upload policy
OBJECT_STORAGE_UPLOAD_URL_EXPIRATION=10m
OBJECT_STORAGE_DOWNLOAD_URL_EXPIRATION=10m
OBJECT_STORAGE_MAX_FILE_SIZE=10485760
OBJECT_STORAGE_KEY_PREFIX=images
